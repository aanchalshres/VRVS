    public function stats()
    {
        $totalUsers = User::count();
        $activeTasks = Task::where('status', 'active')->count();
        $totalNgos = NgoProfile::count();
        return response()->json([
            'total_users' => $totalUsers,
            'active_tasks' => $activeTasks,
            'total_ngos' => $totalNgos,
        ]);
    }
}
