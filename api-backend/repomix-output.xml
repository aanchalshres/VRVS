<file path="app/Algorithms/Matching/HaversineDistance.php">
<?php

namespace App\Algorithms\Matching;

class HaversineDistance
{
    public function calculate(
        float $lat1,
        float $lon1,
        float $lat2,
        float $lon2
    ): float
    {
        $R = 6371;

        $dLat = deg2rad($lat2 - $lat1);

        $dLon = deg2rad($lon2 - $lon1);

        $a =
            sin($dLat / 2) ** 2
            +
            cos(deg2rad($lat1))
            *
            cos(deg2rad($lat2))
            *
            sin($dLon / 2) ** 2;

        return
            $R
            *
            2
            *
            atan2(
                sqrt($a),
                sqrt(1 - $a)
            );
    }
}
