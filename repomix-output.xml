      <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={1.3} d="M8.5 17v-3.25h.85c.55 0 1 .45 1 1s-.45 1-1 1H8.5m3.3.25V13.75m2 3.25v-3.25h1.35" />
