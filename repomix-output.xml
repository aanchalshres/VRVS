                </button>
              </div>
            </div>
          </div>

          {/* Document list */}
          {docsLoading ? (
            <div className="space-y-3 animate-pulse">
              {[...Array(3)].map((_, i) => (
                <div key={i} className="h-12 rounded-lg" style={{ backgroundColor: COLORS.soft, opacity: 0.25 }}></div>
