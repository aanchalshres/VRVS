              {/* Stars */}
              <div className="flex gap-0.5 mb-4">
                {Array.from({ length: t.stars }).map((_, j) => (
                  <span key={j} className="text-lg" style={{ color: '#7683D6' }}>★</span>
                ))}
              </div>

              <p className="text-[14.5px] leading-relaxed mb-6 relative" style={{ color: '#374151' }}>
