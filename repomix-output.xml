                            }
                          >
                            {doc.status}
                          </span>
                        </td>
                        <td className="px-4 py-3 text-sm" style={{ color: COLORS.textSecondary }}>
                          {doc.remarks || "—"}
                        </td>
                        <td className="px-4 py-3 text-sm" style={{ color: COLORS.textSecondary }}>
                          {new Date(doc.created_at).toLocaleDateString()}
                        </td>
                        <td className="px-4 py-3 text-right">
