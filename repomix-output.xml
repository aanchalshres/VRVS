          >
            Organization
          </Link> */}

          <Link
            href="/badges"
            className="text-sm font-medium text-foreground/70 hover:text-foreground transition-colors"
          >
            Badges
          </Link>

          <Link
            href="/about"
            className="text-sm font-medium text-foreground/70 hover:text-foreground transition-colors"
